<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>하이일드 채권 & 펀드 수익률 시뮬레이터</title>
    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #e0e0e0;
            --primary-color: #4caf50;
            --accent-color: #2196f3;
            --border-color: #333;
        }
        body {
            font-family: 'Malgun Gothic', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 20px;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
        }
        h1 {
            text-align: center;
            color: #fff;
            margin-bottom: 30px;
        }
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
        }
        .card {
            background-color: var(--card-bg);
            padding: 25px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }
        .form-group {
            margin-bottom: 18px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            font-size: 0.95rem;
        }
        input, select {
            width: 100%;
            padding: 10px;
            box-sizing: border-box;
            background-color: #2a2a2a;
            border: 1px solid var(--border-color);
            color: #fff;
            border-radius: 6px;
            font-size: 1rem;
        }
        input:focus {
            outline: none;
            border-color: var(--primary-color);
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: var(--primary-color);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 1.1rem;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.2s;
        }
        button:hover {
            background-color: #43a047;
        }
        .result-box {
            margin-top: 20px;
            padding: 15px;
            background-color: #252525;
            border-radius: 6px;
            border-left: 4px solid var(--accent-color);
        }
        .result-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 1.05rem;
        }
        .result-item:last-child { margin-bottom: 0; }
        .highlight {
            font-weight: bold;
            color: #ffb74d;
        }
        
        /* 외부 라이브러리 없이 구현한 CSS 막대 그래프 스타일 */
        .chart-container {
            margin-top: 25px;
        }
        .chart-title {
            font-size: 1.1rem;
            font-weight: bold;
            margin-bottom: 15px;
            color: #fff;
        }
        .bar-wrapper {
            margin-bottom: 12px;
        }
        .bar-label {
            font-size: 0.85rem;
            margin-bottom: 4px;
            color: #aaa;
        }
        .bar-bg {
            background-color: #2a2a2a;
            border-radius: 4px;
            height: 24px;
            width: 100%;
            overflow: hidden;
            position: relative;
        }
        .bar-fill {
            background: linear-gradient(90deg, #2196f3, #00bcd4);
            height: 100%;
            width: 0%; /* JS로 조절 */
            transition: width 0.4s ease-out;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 8px;
            box-sizing: border-box;
        }
        .bar-value {
            font-size: 0.8rem;
            color: #fff;
            font-weight: bold;
            white-space: nowrap;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>📊 글로벌 하이일드 수익률 시뮬레이터</h1>
    
    <div class="grid">
        <div class="card">
            <h3>🛠️ 투자 조건 입력</h3>
            <div class="form-group">
                <label for="initAmount">초기 투자 금액 (원)</label>
                <input type="number" id="initAmount" value="10000000" step="100000">
            </div>
            <div class="form-group">
                <label for="monthlyAmount">매월 추가 적립 금액 (원)</label>
                <input type="number" id="monthlyAmount" value="500000" step="50000">
            </div>
            <div class="form-group">
                <label for="yieldRate">예상 연 수익률 / 표면금리 (%)</label>
                <input type="number" id="yieldRate" value="7.5" step="0.1">
            </div>
            <div class="form-group">
                <label for="years">투자 기간 (년)</label>
                <input type="number" id="years" value="5" min="1" max="10">
            </div>
            <div class="form-group">
                <label for="taxType">계좌 과세 유형</label>
                <select id="taxType">
                    <option value="general">일반 계좌 (15.4% 원천징수)</option>
                    <option value="isa">절세 계좌 / ISA (비과세 가정)</option>
                </select>
            </div>
            <button onclick="calculateYield()">시뮬레이션 실행</button>
        </div>

        <div class="card">
            <h3>📈 시뮬레이션 결과</h3>
            <div class="result-box">
                <div class="result-item">
                    <span>총 납입 원금:</span>
                    <span id="resTotalPrincipal" class="highlight">0원</span>
                </div>
                <div class="result-item">
                    <span>세전 예상 만기금액:</span>
                    <span id="resPreTaxTotal">0원</span>
                </div>
                <div class="result-item">
                    <span>예상 세금:</span>
                    <span id="resTax">0원</span>
                </div>
                <div class="result-item" style="font-size: 1.2rem; margin-top: 10px; border-top: 1px solid #444; padding-top: 10px;">
                    <span><strong>최종 세후 수령액:</strong></span>
                    <span id="resPostTaxTotal" style="color: #4caf50; font-weight: bold;">0원</span>
                </div>
            </div>

            <div class="chart-container">
                <div class="chart-title">연도별 자산 성장 추이 (세전)</div>
                <div id="customChart"></div>
            </div>
        </div>
    </div>
</div>

<script>
function formatCurrency(val) {
    return Math.round(val).toLocaleString() + ' 원';
}

function calculateYield() {
    // 1. 입력값 가공
    const initAmount = parseFloat(document.getElementById('initAmount').value) || 0;
    const monthlyAmount = parseFloat(document.getElementById('monthlyAmount').value) || 0;
    const annualRate = (parseFloat(document.getElementById('yieldRate').value) || 0) / 100;
    const years = parseInt(document.getElementById('years').value) || 1;
    const taxType = document.getElementById('taxType').value;

    const monthlyRate = annualRate / 12;
    const totalMonths = years * 12;

    let currentBalance = initAmount;
    let totalPrincipal = initAmount;

    // 차트 데이터 수집용 배열
    let yearlyData = [{ label: '초기', value: initAmount }];

    // 2. 월별 복리 연산
    for (let m = 1; m <= totalMonths; m++) {
        currentBalance = currentBalance * (1 + monthlyRate) + monthlyAmount;
        totalPrincipal += monthlyAmount;

        if (m % 12 === 0) {
            yearlyData.push({
                label: `${m / 12}년차`,
                value: Math.round(currentBalance)
            });
        }
    }

    // 3. 세금 및 세후 금액 연산
    const totalInterest = currentBalance - totalPrincipal;
    let tax = 0;
    if (taxType === 'general' && totalInterest > 0) {
        tax = totalInterest * 0.154;
    }
    const postTaxTotal = currentBalance - tax;

    // 4. 결과를 화면에 텍스트로 노출
    document.getElementById('resTotalPrincipal').innerText = formatCurrency(totalPrincipal);
    document.getElementById('resPreTaxTotal').innerText = formatCurrency(currentBalance);
    document.getElementById('resTax').innerText = formatCurrency(tax);
    document.getElementById('resPostTaxTotal').innerText = formatCurrency(postTaxTotal);

    // 5. HTML/CSS 동적 막대 그래프 생성
    renderCustomChart(yearlyData);
}

function renderCustomChart(data) {
    const chartWrapper = document.getElementById('customChart');
    chartWrapper.innerHTML = ''; // 기존 그래프 초기화

    // 가장 큰 금액을 기준으로 막대 길이(%) 비율을 계산하기 위함
    const maxValue = data[data.length - 1].value || 1;

    data.forEach(item => {
        const percentage = (item.value / maxValue) * 100;

        // HTML 태그를 문자열로 동적 생성
        const barHtml = `
            <div class="bar-wrapper">
                <div class="bar-label">${item.label}</div>
                <div class="bar-bg">
                    <div class="bar-fill" style="width: ${percentage}%">
                        <span class="bar-value">${formatCurrency(item.value)}</span>
                    </div>
                </div>
            </div>
        `;
        chartWrapper.innerHTML += barHtml;
    });
}

// 최초 실행
window.onload = function() {
    calculateYield();
};
</script>
</body>
</html>
